# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_EXPIRES_IN=8h

# ── RSU API Key ───────────────────────────────────────────────────────────────
# Shared secret between RSU firmware and CMS — must match RSU config.h
RSU_API_KEY=REPLACE_WITH_RSU_SECRET

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# ── ML Microservice ───────────────────────────────────────────────────────────
ML_SERVICE_URL=https://vanet-ml-service.onrender.com
